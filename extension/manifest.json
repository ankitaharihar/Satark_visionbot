{
  "manifest_version": 3,
  "name": "Satark Vision URL Shield",
  "description": "Detect phishing URLs using Satark local AI API.",
  "version": "1.0.0",
  "action": {
    "default_title": "Satark Scan",
    "default_popup": "popup.html"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
